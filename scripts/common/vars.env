# ==========================================================================
# Variáveis compartilhadas do projeto Mini-IPTV (TechNova, grupo 4).
# Todos os scripts de etapa leem este arquivo. Edite só se precisar.
# ==========================================================================

DOMAIN="tecnova.com.br"
GRUPO=4
NCH=18                 # quantidade de canais (multicast 239.x.4.1..18)
MCAST_PORT=5004

# Endereços fixos
S_IP="172.16.0.2"      # host S (LAN #1)
R1_IP="172.16.0.1"     # R1 lado LAN #1
R2_IP="192.168.0.1"    # R2 lado LAN #2
PPP_R1="10.0.0.1"      # ponta PPP no R1
PPP_R2="10.0.0.2"      # ponta PPP no R2
BAUD=115200            # taxa do enlace serial (exigida pelo enunciado)

# Interfaces: deixe VAZIO para detectar automaticamente, ou escreva o nome real
# (descubra com:  ip -br link)
IF_S=""                # placa do S
IF_R1_LAN1=""          # placa do R1 ligada ao S
IF_R1_LAB=""           # placa do R1 com internet do laboratório
IF_R2_LAN2=""          # placa do R2 ligada ao switch (X/Y)
IF_CLIENT=""           # placa do cliente (X ou Y)
SERIAL=""              # /dev/ttyUSB0 (físico) ou /dev/ttyS0 (VM); vazio = detectar
